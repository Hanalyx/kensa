# Go
*.test
*.out
*.prof
coverage.txt
coverage.html

# Build artifacts (root-level compiled binaries; anchored so cmd/ source dirs are not ignored)
/bin/
/dist/
/kensa
/kensa-fuzz
/kensa-validate
/kensa-keygen
/kensa-systemd-helper
/bench_aggregate

# Editor
.vscode/
.idea/
*.swp
*~

# Kensa runtime state — never commit
.kensa/
/tmp-test-hosts/

# Local
CLAUDE.md
inventory.ini

# Internal docs surface — vision, roadmap, foundation contracts, AI
# session logs, founder release sign-off. Kept locally as working
# notes; not part of the published repo. Only docs/guide/ (operator
# guide) is tracked.
/docs/*
!/docs/guide/
!/docs/.gitignore

# Local-only artifacts
# Agent runtime config is local-only, EXCEPT shared skills, which are tracked
# so contributors get them from a clean clone.
.claude/*
!.claude/skills/
.specter-results.json
go-test.json

# Live-host scan artifacts (evidence/OSCAL); generated, contain host data
results/

# kensa-catalog default db path (when -db is not given)
catalog.db
